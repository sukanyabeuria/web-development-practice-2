<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Filter Strings Example</title>
</head>
<body>
  <h1>Filtered Array Output</h1>
  <p id="output"></p>

  <script>
    let arr = ["squirrel", 5, "Tjed", new Date(), true]; 
    let bb = ["so", "bye", "bye", "love"]; 
console.log(bb.lastIndexOf("hi"));


    function checkString(element, index) { 
      return typeof element === "string"; 
    } 

    let filterArr = arr.filter(checkString); 
    console.log(filterArr); 

    
    document.getElementById("output").textContent = "Filtered strings: " + filterArr.join(", ");
  </script>
</body>
</html>
