<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>String Split Example</title>
</head>
<body>
  <h1>String Split Demo</h1>
  <p id="output"></p>

  <script>
    // Original string
    let result = "Hello JavaScript"; 
    
    // Split the string into an array by spaces
    let arr_result = result.split(" "); 
    
    // Log to console
    console.log(arr_result); 
    
    // Display on the page
    document.getElementById("output").textContent = "Resulting array: [" + arr_result.join(", ") + "]";
  </script>
</body>
</html>
