<!DOCTYPE html>
<html>
<head>
  <title>Q9 - Scholarship Eligibility</title>
</head>
<body>
  <h2>Q9: Scholarship Eligibility Program</h2>

  <label>Enter Marks: </label>
  <input type="number" id="marksInput"><br><br>

  <label>Enter Family Income: </label>
  <input type="number" id="incomeInput"><br><br>

  <button onclick="checkScholarship()">Check Eligibility</button>

  <p id="result"></p>

  <script>
    function checkScholarship() {
      let marks = parseInt(document.getElementById("marksInput").value);
      let income = parseInt(document.getElementById("incomeInput").value);
      let result = "";

      if (marks >= 85 || (marks >= 75 && income < 300000)) {
        result = "Eligible for Scholarship";
      } else {
        result = "Not Eligible for Scholarship";
      }

      document.getElementById("result").textContent = result;
    }
  </script>
</body>
</html>
