<!DOCTYPE html>
<html>
<head>
  <title>Q8 - Grading System (Switch-Case)</title>
</head>
<body>
  <h2>Q8: Grading System using Switch-Case</h2>

  <label>Enter Score: </label>
  <input type="number" id="scoreInput">
  <button onclick="getGrade()">Check Grade</button>

  <p id="result"></p>

  <script>
    function getGrade() {
      let score = parseInt(document.getElementById("scoreInput").value);
      let grade;

      // Switch-case based on ranges
      switch (true) {
        case (score >= 90):
          grade = "A";
          break;
        case (score >= 75 && score < 90):
          grade = "B";
          break;
        case (score >= 50 && score < 75):
          grade = "C";
          break;
        case (score < 50):
          grade = "F";
          break;
        default:
          grade = "Invalid Score";
      }

      document.getElementById("result").textContent = "Grade: " + grade;
    }
  </script>
</body>
</html>
