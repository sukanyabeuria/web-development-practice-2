<!DOCTYPE html>
<html>
<head>
  <title>Q10 - Final Payable Amount</title>
</head>
<body>
  <h2>Q10: Calculate Final Payable Amount</h2>

  <label>Enter Purchase Value: </label>
  <input type="number" id="valueInput">
  <button onclick="calculateAmount()">Calculate</button>

  <p id="result"></p>

  <script>
    function calculateAmount() {
      let value = parseFloat(document.getElementById("valueInput").value);
      let discount = 0;

      if (value >= 5000) {
        discount = 0.30; // 30% discount
      } else if (value >= 2000) {
        discount = 0.10; // 10% discount
      } else {
        discount = 0;    // no discount
      }

      let finalAmount = value - (value * discount);
      document.getElementById("result").textContent =
        "Final Payable Amount = " + finalAmount.toFixed(2);
    }
  </script>
</body>
</html>
