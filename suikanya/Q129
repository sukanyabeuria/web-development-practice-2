<!DOCTYPE html>
<html>
<head>
  <title>Map Demo</title>
</head>
<body>
  <h2>JavaScript map() Example</h2>
  <p id="output"></p>

  <script>
    let arr = [1, 2, 3, 4]; 
    let mapped_arr = arr.map(x => x + 1); 
    document.getElementById("output").textContent = mapped_arr;
    console.log(mapped_arr); 
    </script>
</body>
</html>