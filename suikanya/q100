<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Say Hello Example</title>
</head>
<body>
  <h1>Welcome!</h1>
  <button onclick="sayHello()">Click to Say Hello</button>

  <script>
    function sayHello() {
      let you = prompt("What's your name?");
      console.log("Hello", you + "!");
      alert("Hello " + you + "!"); // optional: shows greeting in a popup
    }
  </script>
</body>
</html>
