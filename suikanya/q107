<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Default Parameters Example</title>
</head>
<body>
  <h1>Default Parameters Demo</h1>

  <script>
    function addTwoNumbers(x = 2, y = 3) {
      console.log("Result:", x + y);
    }

    
    addTwoNumbers(6,5);        
    addTwoNumbers(10);  
    addTwoNumbers();      
    addTwoNumbers(10,20,30,40,50);     
  </script>
</body>
</html>
