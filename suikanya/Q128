<!DOCTYPE html>
<html>
<head>
  <title>copyWithin Demo</title>
</head>
<body>
  <h2>JavaScript copyWithin Example</h2>
  <p id="output"></p>

  <script>
    let arr = ["grapefruit", 4, "hello", 5.6, true];
    arr.copyWithin(0, 3, 4);
    document.getElementById("output").textContent = arr;
  </script>
</body>
</html>
