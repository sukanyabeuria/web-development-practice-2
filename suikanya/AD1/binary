public class Binary_search{
public static int bs_Recursive(int []A, int key,int p , int r){
    if (p>r)
    return -1;
     int mid = (p+r)/2;
     if (A[mid]== key)
     return mid;
     else if (A[mid]<key)
     return bs_Recursive(A,key, mid+1, r);
     else 
     return bs_Recursive(A, key,mid-1);
}
